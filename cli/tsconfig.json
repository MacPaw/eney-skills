{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "rewriteRelativeImportExtensions": true,
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true
  },
  "types": [
    "node"
  ],
  "include": [
    "**/*.js",
    "**/*.ts",
    "*.js",
    "*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "engines": {
    "node": ">=24"
  }
}
