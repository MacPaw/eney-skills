{
  "name": "markdown-to-html-mcp",
  "version": "1.0.0",
  "type": "module",
  "description": "Markdown to HTML MCP server",
  "main": "index.js",
  "scripts": {
    "start": "npx tsx index.ts",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "test": "npx tsx --test tests/*.test.ts",
    "build": "tsc",
    "postbuild": "cp manifest.json dist/manifest.json && cp -r node_modules dist/node_modules"
  },
  "dependencies": {
    "@eney/api": "^2.2.1",
    "@modelcontextprotocol/sdk": "^1.24.3",
    "@types/markdown-it": "^14.1.2",
    "@types/sanitize-html": "^2.16.1",
    "markdown-it": "^14.1.1",
    "react": "^18.3.1",
    "sanitize-html": "^2.17.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.27",
    "typescript": "^5.9.3"
  }
}
