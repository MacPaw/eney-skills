{
  "name": "pdf-utilities",
  "description": "PDF files utilities extensions",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "bundle": "node ../../cli/main.ts bundle",
    "build": "npm run typecheck && npm run bundle",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run typecheck && npm run bundle"
  },
  "dependencies": {
    "@macpaw/eney-api": "1.2.3",
    "pdf-lib": "^1.17.1",
    "tmp": "^0.2.5",
    "zod": "^4.1.0"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.26",
    "@types/tmp": "^0.2.6",
    "typescript": "^5.6.3"
  }
}
