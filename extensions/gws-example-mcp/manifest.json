{
  "manifest_version": "0.3",
  "name": "gws-example-mcp",
  "version": "1.0.0",
  "description": "Google Workspace Example MCP server",
  "author": {
    "name": ""
  },
  "server": {
    "type": "node",
    "entry_point": "index.js",
    "mcp_config": {
      "command": "node",
      "args": [
        "${__dirname}/index.js"
      ],
      "env": {
        "GOOGLE_WORKSPACE_CLI_TOKEN": "${user_config.gcalendar}",
        "GOOGLE_DRIVE_TOKEN": "${user_config.gdrive}",
        "GOOGLE_MEET_TOKEN": "${user_config.gcalendar}",
        "GOOGLE_TASKS_TOKEN": "${user_config.gcalendar}",
        "GOOGLE_DOCS_TOKEN": "${user_config.gdrive}"
      }
    }
  },
  "user_config": {
    "gcalendar": {
      "type": "string",
      "title": "Google Calendar Access Token",
      "description": "A valid Google OAuth2 access token with Calendar read scope.",
      "sensitive": true,
      "required": false
    },
    "gdrive": {
      "type": "string",
      "title": "Google Drive Access Token",
      "description": "A valid Google OAuth2 access token with Drive read/write scope.",
      "sensitive": true,
      "required": false
    }
  },
  "license": "MIT"
}
