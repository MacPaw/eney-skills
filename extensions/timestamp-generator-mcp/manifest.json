{
  "manifest_version": "0.3",
  "name": "timestamp-generator-mcp",
  "version": "1.0.0",
  "description": "Generate timestamps from a YouTube video URL or an uploaded audio/video file",
  "author": {
    "name": "Olha"
  },
  "server": {
    "type": "node",
    "entry_point": "index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/index.js"],
      "env": {}
    }
  },
  "license": "MIT"
}
