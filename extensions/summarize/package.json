    "zod": "^4.1.0"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@types/jsdom": "21.1.7",
    "@types/mozilla-readability": "0.2.1",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.26",
    "typescript": "^5.6.3"
  }
}
