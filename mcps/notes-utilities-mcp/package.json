{
  "name": "notes-utilities-mcp",
  "version": "1.0.1",
  "type": "module",
  "description": "Notes Utilities MCP server",
  "main": "index.js",
  "scripts": {
    "start": "tsx index.ts",
    "build": "tsc",
    "postbuild": "npm ci && cp manifest.json dist/manifest.json && cp -r node_modules dist/node_modules && npm i",
    "clean": "rm -rf dist",
    "prepack": "npm run clean && npm run build",
    "pack": "mcpb pack dist"
  },
  "dependencies": {
    "@macpaw/eney-api": "^2.5.0-beta.5",
    "@modelcontextprotocol/sdk": "^1.24.3",
    "lodash": "^4.17.21",
    "markdown-it": "^14.1.0",
    "react": "^18.3.1",
    "sanitize-html": "^2.13.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.7",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.27",
    "@types/sanitize-html": "^2.13.0",
    "typescript": "^5.9.3"
  }
}
