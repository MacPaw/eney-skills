{
  "name": "send-mail-mcp",
  "version": "1.0.0",
  "type": "module",
  "description": "Send Mail MCP server",
  "main": "index.js",
  "scripts": {
    "start": "tsx index.ts",
    "build": "tsc",
    "postbuild": "npm i --omit=dev && cp manifest.json dist/manifest.json && cp -r node_modules dist/node_modules && npm i",
    "clean": "rm -rf dist",
    "prepack": "npm run clean && npm run build",
    "pack": "mcpb pack dist"
  },
  "dependencies": {
    "@macpaw/eney-api": "^2.4.0-beta.3",
    "@modelcontextprotocol/sdk": "^1.24.3",
    "react": "^18.3.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.27",
    "typescript": "^5.9.3"
  }
}
